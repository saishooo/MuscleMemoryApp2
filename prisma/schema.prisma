generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String           @id @default(cuid())
  username  String           @unique
  nickname  String
  email     String           @unique
  password  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  goals     Goal[]
  records   Record[]
  sessions  WorkoutSession[]
}

model ExerciseCategory {
  id        String     @id @default(cuid())
  name      String     @unique

  exercises Exercise[]
}

model Exercise {
  id         String           @id @default(cuid())
  name       String           @unique
  categoryId String
  category   ExerciseCategory @relation(fields: [categoryId], references: [id])

  goals      Goal[]
  records    Record[]
  trainings  Training[]
}

model WorkoutSession {
  id        String     @id @default(cuid())
  userId    String
  date      DateTime
  user      User       @relation(fields: [userId], references: [id])

  trainings Training[]

  @@unique([userId, date])
}

model Training {
  id         String         @id @default(cuid())
  sessionId  String
  exerciseId String
  weight     Float
  reps       Int
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  session    WorkoutSession @relation(fields: [sessionId], references: [id])
  exercise   Exercise       @relation(fields: [exerciseId], references: [id])
}

model Record {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  maxWeight  Float
  maxReps    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  exercise   Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([userId, exerciseId])
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  exerciseId   String
  targetWeight Float
  targetReps   Int
  deadline     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  exercise     Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([userId, exerciseId])
}
